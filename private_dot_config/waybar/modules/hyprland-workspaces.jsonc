{
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "๓ฐฒก", "2": "๓ฐฒฃ", "3": "๓ฐฒฅ",
            "4": "๓ฐฒง", "5": "๓ฐฒฉ",
            "active": "๓ฐฎฏ",
            "default": "๓ฐ "
        },
        "persistent-workspaces": { "*": 5 },
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1"
    }
}
