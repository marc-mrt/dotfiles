# dunstrc-colors
[urgency_low]
    background  = "#{{colors.surface.default.hex_stripped}}cc"
    foreground  = "#{{colors.on_surface.default.hex_stripped}}ee"
    frame_color = "{{colors.secondary.default.hex}}"
    timeout     = 4

[urgency_normal]
    background  = "#{{colors.surface.default.hex_stripped}}cc"
    foreground  = "#{{colors.on_surface.default.hex_stripped}}ee"
    frame_color = "{{colors.primary.default.hex}}"
    timeout     = 6

[urgency_critical]
    background  = "{{colors.surface.default.hex}}"
    foreground  = "{{colors.on_surface.default.hex}}"
    frame_color = "{{colors.error.default.hex}}"
    timeout     = 0
